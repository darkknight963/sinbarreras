# Desarrollo local. Copia este archivo a `.env` y cambia estos valores en producción.
NODE_ENV=development
# ADVERTENCIA CRÍTICA: Mantener en false en producción.
# Si se pone true en producción, TypeORM puede alterar o eliminar columnas al hacer deploy.
# Usa migraciones (npm run migration:run) para cambios de esquema en producción.
DB_SYNCHRONIZE=false
# Producción: reemplaza por el usuario real de PostgreSQL.
DB_USER=postgres
# Producción: reemplaza por la contraseña real de PostgreSQL.
DB_PASSWORD=postgres
DB_NAME=accessibility_db
# Producción: reemplaza por el usuario real de MinIO/S3.
MINIO_ROOT_USER=admin
# Producción: reemplaza por la contraseña real de MinIO/S3.
MINIO_ROOT_PASSWORD=admin123
# Producción: define cuántos días conservar evidencias; 0 o vacío desactiva la limpieza automática.
EVIDENCE_RETENTION_DAYS=0
