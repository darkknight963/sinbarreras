{
  "manifest_version": 3,
  "name": "Sin Barreras - Auditoría autenticada",
  "version": "2.2.1",
  "description": "Escanea la pestaña autenticada actual sin guardar credenciales y envía resultados a Sin Barreras.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://sinbarreras.gzakgroup.com/*",
    "https://api.gzakgroup.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://sinbarreras.gzakgroup.com/*",
      "https://www.sinbarreras.gzakgroup.com/*",
      "https://api.gzakgroup.com/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auditar con Sin Barreras",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
