{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /c \"(git rev-parse --git-dir >NUL 2>NUL && code-review-graph update --skip-flows --repo C:\\Users\\URQUIA\\Downloads\\PROYECTO_ACCESIBILIDAD) & exit /b 0\"",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /c \"(git rev-parse --git-dir >NUL 2>NUL && code-review-graph status --repo C:\\Users\\URQUIA\\Downloads\\PROYECTO_ACCESIBILIDAD || echo Not a git repo, skipping) & exit /b 0\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
